# 复制到仓库根目录为 .env（或 export 后执行 compose），勿提交真实密码
# 用法：cp deploy/env.prod.example .env

MYSQL_ROOT_PASSWORD=请替换为强密码
MYSQL_DATABASE=meikai
MYSQL_USER=meikai
MYSQL_PASSWORD=请替换为强密码

# 浏览器访问前端的 https 源（逗号分隔，须含主域名与裸域）
CORS_ORIGINS=https://www.meikaizs.com,https://meikaizs.com

# 构建前端时写入 SEO / canonical（与实际上线域名一致）
VITE_SITE_ORIGIN=https://www.meikaizs.com

# init-letsencrypt.sh 申请 Let's Encrypt 证书（必填，改成你的邮箱）
SSL_EMAIL=your@email.com
