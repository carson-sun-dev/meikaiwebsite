# 仓库根 .env 模板 — 给 docker compose 用(不是 ai-service 的)
# 用法:cp deploy/env.prod.example .env;复制后自动被 .gitignore
#
# 所有字段都必填。MYSQL_PASSWORD / QDRANT_API_KEY 必须与 ai-service/.env 一致。

# --- MySQL ---
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
MYSQL_DATABASE=meikai
MYSQL_USER=meikai

# --- Qdrant(同 ai-service/.env 的 QDRANT_API_KEY)---
QDRANT_API_KEY=

# --- 站点域名(本地预演改 http://localhost)---
CORS_ORIGINS=https://www.meikaizs.com,https://meikaizs.com
VITE_SITE_ORIGIN=https://www.meikaizs.com

# --- LLM 模式(线上 live;本地预演也用 live 真烧 Key 验)---
LLM_MODE=live

# --- Let's Encrypt(仅服务器首次申请证书时用,本地预演无需填)---
SSL_EMAIL=
