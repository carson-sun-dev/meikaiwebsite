# ============================================================
# ai-service 本地完整版配置(MacBook M5 16G / 临时 4C8G 云机)
# DESIGN §2.4 双 Compose 双 .env 中的「FULL 路径」
#
# 用途:开发主路径,跑本地 bge-m3 + bge-reranker + PaddleOCR,
#       产出双路径评测数据 + demo 视频素材。
# 切换:复制为 .env(已在 .gitignore),启动 docker-compose.full.yml
#
# ⚠️ 重要:所有注释必须独占一行,不要写在 KEY=VALUE 后面!
#    python-dotenv 对"空值 + 行内注释"会把注释吞进 value(如 KEY=  # x 会被读成 KEY='# x'),
#    曾经导致 Qdrant client 报 UnicodeEncodeError。
# ============================================================

# --- 服务 ---
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- LLM 模式(Sprint 1/2 走 mock,Sprint 3 切真值)---
# llm_mode: mock | live
LLM_MODE=mock

# --- 火山方舟统一入口(2026-06 起 L0/L2/Embedding/Vision 一份 key)---
# 获取:https://console.volcengine.com/ark → API Key 管理
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 火山方舟 endpoint ID(必须用 ID,不是模型名)---
# 在火山控制台「在线推理」页创建推理接入点,拷贝 ep-xxxxxx 格式的 ID
# L0:Doubao-1.5-lite-32k → 意图分类 / 闲聊 / ETL 打标
DOUBAO_LITE_ENDPOINT=
# L2:DeepSeek-V3.2 → 核心对话 + 复杂报价
DEEPSEEK_ENDPOINT=
# Embedding:Doubao-embedding → 生产路径 embedding(本地仍走 bge-m3)
DOUBAO_EMBEDDING_ENDPOINT=
# Vision:Doubao-1.5-vision-pro-32k → 户型图理解(Sprint 2)
DOUBAO_VISION_ENDPOINT=

# --- Provider 抽象(DESIGN §2.3)— 本地完整版默认全 local_* ---
# embedding_provider: mock | local_bge_m3 | doubao
EMBEDDING_PROVIDER=local_bge_m3
# reranker_provider: mock | local_bge_reranker | volc
RERANKER_PROVIDER=local_bge_reranker
# ocr_provider: mock | local_paddleocr | baidu | aliyun | doubao
OCR_PROVIDER=local_paddleocr

# 云 OCR(本地路径用不到,留空)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# 云 Reranker(本地路径用不到,留空)
VOLC_RERANKER_API_KEY=
VOLC_RERANKER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- Qdrant(本地 Docker)---
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY 本地可空;生产必填
QDRANT_API_KEY=

# --- MySQL(复用现网 meikai 库)---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=meikai
MYSQL_PASSWORD=
MYSQL_DB=meikai

# --- Backend(转人工时回调留资接口 /api/leads/quote)---
BACKEND_INTERNAL_URL=http://backend:3001

# --- LangFuse(开发期也走 Cloud,省 ~2GB 本地内存)---
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Guardrail / 资源闸 ---
ALLOWED_ORIGINS=https://www.meikaizs.com,https://meikaizs.com,http://localhost:5173
MAX_UPLOAD_MB=20
# DESIGN §11.1:FastAPI 进程内 Semaphore
MAX_CONCURRENT_SESSIONS=8
# 可用内存 < 此值即降级到纯对话路径
MEMORY_DEGRADE_MB=400

# --- 营销折扣系数(DESIGN §7 产品规则)---
# 展示价 = 历史真实价 * QUOTE_DISPLAY_FACTOR
# 本系统是宣传用 AI 客服,展示价低于真实历史价吸引留资,精确价由销售接洽时谈
# 建议范围 0.85-0.95;Guardrail 输出侧仍以原始数据校验,与本系数解耦
QUOTE_DISPLAY_FACTOR=0.9
