# ============================================================
# ai-service 生产 2C4G 配置(用户决定上线时切换)
# DESIGN §2.4 双 Compose 双 .env 中的「PROD/LITE 路径」
#
# 用途:2 vCPU / 4 GB RAM / 60 GB SSD 长租机
# 切换:复制为 .env(已在 .gitignore),启动 docker-compose.prod.yml
# 与 full 的差异只在 *_PROVIDER + LANGFUSE_HOST + 真实 API Key
#
# ⚠️ 重要:所有注释必须独占一行,不要写在 KEY=VALUE 后面!
#    python-dotenv 对"空值 + 行内注释"会把注释吞进 value(如 KEY=  # x 会被读成 KEY='# x'),
#    曾经导致 Qdrant client 报 UnicodeEncodeError。
# ============================================================

# --- 服务 ---
APP_ENV=prod
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- LLM 模式(生产 live)---
LLM_MODE=live

# --- 火山方舟统一入口(必填)---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 火山方舟 endpoint ID(必填)---
DOUBAO_LITE_ENDPOINT=
DEEPSEEK_ENDPOINT=
DOUBAO_EMBEDDING_ENDPOINT=
DOUBAO_VISION_ENDPOINT=

# --- Provider 抽象(DESIGN §2.3)— 生产全 API,本地权重不进镜像 ---
# embedding_provider: 本地 local_bge_m3 ↔ 生产 doubao
EMBEDDING_PROVIDER=doubao
# reranker_provider: 本地 local_bge_reranker ↔ 生产 volc
RERANKER_PROVIDER=volc
# ocr_provider: 本地 local_paddleocr ↔ 生产 baidu
OCR_PROVIDER=baidu

# 云 OCR(必填)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# 云 Reranker(必填)
VOLC_RERANKER_API_KEY=
VOLC_RERANKER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- Qdrant(本地 Docker,生产同机)---
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY 生产必填
QDRANT_API_KEY=

# --- MySQL(复用现网 meikai 库)---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=meikai
MYSQL_PASSWORD=
MYSQL_DB=meikai

# --- Backend(转人工时回调留资接口 /api/leads/quote)---
BACKEND_INTERNAL_URL=http://backend:3001

# --- LangFuse(生产用 Cloud)---
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Guardrail / 资源闸(生产更紧)---
ALLOWED_ORIGINS=https://www.meikaizs.com,https://meikaizs.com
MAX_UPLOAD_MB=20
MAX_CONCURRENT_SESSIONS=8
MEMORY_DEGRADE_MB=400

# --- 营销折扣系数(DESIGN §7 产品规则)---
# 展示价 = 历史真实价 * QUOTE_DISPLAY_FACTOR
QUOTE_DISPLAY_FACTOR=0.9
