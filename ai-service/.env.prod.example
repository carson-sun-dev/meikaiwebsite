# ============================================================
# ai-service 生产 .env 模板 — 仅列需要你填的字段
# 用法:cp .env.prod.example .env 后填空值;复制后 .env 自动被 .gitignore
#
# ⚠️ 重要:所有注释独占一行,不要写在 KEY=VALUE 后面
#    python-dotenv 对"空值 + 行内注释"会把注释吞进 value
#    (例:KEY=  # x 会读成 KEY='# x'),曾导致 Qdrant client UnicodeEncodeError
#
# 其余字段(host/port/log_level/base_url/qdrant_url/mysql_host 等)走
# app/config.py 默认值,compose 内 service 名已对齐,无需在此覆盖
# ============================================================

# ------------------------------------------------------------
# §1 必填 — 第三方 API Key
# ------------------------------------------------------------

# 火山方舟统一入口(必填) — https://www.volcengine.com/product/ark
DOUBAO_API_KEY=

# 火山方舟 endpoint ID(必填,Ark 控制台「在线推理」→ 接入点)
# 格式 ep-xxxxxxxxxx
DOUBAO_LITE_ENDPOINT=
DEEPSEEK_ENDPOINT=
DOUBAO_EMBEDDING_ENDPOINT=

# Sprint 2 OCR 兜底用,可暂留空
DOUBAO_VISION_ENDPOINT=

# Volc Reranker(必填) — 一般与 DOUBAO_API_KEY 同
VOLC_RERANKER_API_KEY=

# Qdrant 自定义密码(必填,自己编一段强密码,与仓库根 .env 的 QDRANT_API_KEY 一致)
QDRANT_API_KEY=

# MySQL 密码(必填,与仓库根 .env 的 MYSQL_PASSWORD 一致)
MYSQL_PASSWORD=

# ------------------------------------------------------------
# §2 可选 — 视功能取舍填
# ------------------------------------------------------------

# 百度 OCR(开 CAD/图纸上传才需) — https://ai.baidu.com/tech/ocr_general
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# LangFuse Cloud 观测(不开则留空,不影响功能) — https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ------------------------------------------------------------
# §3 必备覆盖 — 与 config.py 默认值不同,生产必须设
# ------------------------------------------------------------

APP_ENV=prod
LLM_MODE=live

# Provider 切到云端(config.py 默认是本地,生产镜像不含本地权重)
EMBEDDING_PROVIDER=doubao
RERANKER_PROVIDER=volc
OCR_PROVIDER=baidu

# 浏览器源白名单(本地预演改 http://localhost)
ALLOWED_ORIGINS=https://www.meikaizs.com,https://meikaizs.com
