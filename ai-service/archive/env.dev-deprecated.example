# 复制为 .env 后由 docker compose 读取（勿提交真实密码到 Git）

MYSQL_ROOT_PASSWORD=devroot_change_me
MYSQL_DATABASE=meikai
MYSQL_USER=meikai
MYSQL_PASSWORD=meikai_pass_change_me

# 宿主机访问网站的端口
WEB_PORT=8080

# 浏览器里实际访问前端的地址（用于后端 CORS），多个逗号分隔
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://www.meikaizs.com,https://meikaizs.com

# 生产环境完整示例与 SSL 步骤见 deploy/TENCENT_CLOUD.md、deploy/env.prod.example
